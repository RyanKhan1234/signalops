# SignalOps — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Lines starting with # are comments.
# Never commit .env to git — it is listed in .gitignore.

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — Must be set before starting the stack
# ═══════════════════════════════════════════════════════════════════════════════

# Claude API key for the Agent Orchestrator (LangChain uses this via Anthropic SDK)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# SerpApi key for the MCP Wrapper (Google News engine)
# Get your key at: https://serpapi.com/
SERPAPI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL credentials (used by postgres container and all services connecting to it)
POSTGRES_USER=signalops
POSTGRES_PASSWORD=signalops
POSTGRES_DB=signalops

# Full SQLAlchemy async connection URL (used by traceability-store service)
# In Docker Compose: hostname is the service name "postgres"
# For local development outside Docker: use "localhost" instead of "postgres"
DATABASE_URL=postgresql+asyncpg://signalops:signalops@postgres:5432/signalops

# Connection pool settings (traceability-store)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ═══════════════════════════════════════════════════════════════════════════════
# SERVICE URLS — Docker internal networking
# ═══════════════════════════════════════════════════════════════════════════════

# Agent Orchestrator → MCP Wrapper (Docker internal hostname)
MCP_WRAPPER_URL=http://mcp-wrapper:8001

# Agent Orchestrator → Traceability Store (Docker internal hostname)
TRACEABILITY_STORE_URL=http://traceability-store:8002

# Web App → Agent Orchestrator (browser-facing, must be localhost or public URL)
# In Docker Compose: browser connects to localhost:8000, not the container hostname
VITE_API_BASE_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════════════════════
# MCP WRAPPER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# SerpApi base URL — override for testing against a mock server
SERPAPI_BASE_URL=https://serpapi.com/search

# News search cache TTL in seconds (default: 15 minutes)
CACHE_TTL_SECONDS=900

# Per-minute SerpApi call limit (per PRD section 5.2)
RATE_LIMIT_PER_MINUTE=30

# Per-day SerpApi call limit
RATE_LIMIT_PER_DAY=1000

# MCP server transport: "stdio" (for subprocess use) or "sse" (for HTTP clients)
MCP_TRANSPORT=sse

# ═══════════════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════════════════

# Log verbosity across all services: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT ONLY
# ═══════════════════════════════════════════════════════════════════════════════

# LangChain chain tracing (set to "true" to enable LangSmith tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_VERBOSE=0

# SQLAlchemy query logging (set to "true" for verbose SQL in logs)
DB_ECHO=false

# E2E test overrides
ORCHESTRATOR_URL=http://localhost:8000
TRACEABILITY_URL=http://localhost:8002
E2E_TIMEOUT=60
