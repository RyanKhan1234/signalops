# Agent Orchestrator — Environment Variables
# Copy this file to .env and fill in your values.

# Anthropic API key for LLM calls
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (default: claude-opus-4-6)
ANTHROPIC_MODEL=claude-opus-4-6

# MCP Wrapper service URL
MCP_WRAPPER_URL=http://localhost:8001

# Traceability Store service URL
TRACEABILITY_STORE_URL=http://localhost:8002

# FastAPI server config
HOST=0.0.0.0
PORT=8000

# Maximum retries for guardrails validation loop
GUARDRAILS_MAX_RETRIES=2

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Correlation ID header name
CORRELATION_ID_HEADER=X-Request-ID
