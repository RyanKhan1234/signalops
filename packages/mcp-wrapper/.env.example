# === Required ===
SERPAPI_API_KEY=           # Required. Your SerpApi API key from https://serpapi.com/manage-api-key

# === Optional SerpApi overrides ===
SERPAPI_BASE_URL=https://serpapi.com/search

# === Cache ===
CACHE_TTL_SECONDS=900      # 15 minutes for news search results
CACHE_TTL_METADATA_SECONDS=3600  # 1 hour for article metadata

# === Rate limiting ===
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=1000

# === MCP transport ===
MCP_TRANSPORT=stdio        # "stdio" or "sse"
MCP_SSE_PORT=8001          # Port for SSE transport (only used when MCP_TRANSPORT=sse)

# === Logging ===
LOG_LEVEL=INFO
